# ═══════════════════════════════════════════════════════════════════
# AI Investment Research Agent — Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your API keys.
# NEVER commit .env.local to version control.

# ── Required ────────────────────────────────────────────────────────
# Google Gemini API key — https://aistudio.google.com/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# Tavily Search API key — https://app.tavily.com
TAVILY_API_KEY="your_tavily_api_key_here"

# ── Optional: LangSmith Tracing ─────────────────────────────────────
# Enables observability and trace inspection for the LangGraph workflow.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY="your_langsmith_api_key_here"
# LANGCHAIN_PROJECT="ai-investment-research-agent"
